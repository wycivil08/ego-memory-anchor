# ego-memory-anchor Production Environment Variables
# Copy this file to .env.production and fill in your actual values

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (server-side scripts only, NEVER expose to client)
# Get from: https://supabase.com/dashboard/project/_/settings/api -> service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application URL (used for invite links and family member URLs)
NEXT_PUBLIC_BASE_URL=https://your-domain.com
