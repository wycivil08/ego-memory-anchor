# ego-memory-anchor Production Environment Variables
# Copy this file to .env.production and fill in your actual values

# Supabase Configuration
# Get these from your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Supabase Service Role Key (server-side only, never expose to client)
# Get from Supabase project settings -> API -> service_role secret
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application URL (used for redirects and metadata)
NEXT_PUBLIC_APP_URL=https://your-domain.com
